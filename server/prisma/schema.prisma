generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings       UserSettings?
  matchPlayers   MatchPlayer[]
  scoredMatches  Match[]       @relation("ScoredBy")
}

model UserSettings {
  id                    String  @id @default(uuid())
  userId                String  @unique
  user                  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  autoRotateStrike      Boolean @default(true)
  maidenOverAlert       Boolean @default(true)
  confirmBeforeWicket   Boolean @default(true)
  showWagonWheel        Boolean @default(true)
  showRrrLive           Boolean @default(true)
  autoExportPdf         Boolean @default(false)
  defaultFormat         String  @default("T20")
}

model Match {
  id              String   @id @default(uuid())
  uniqueCode      String   @unique
  title           String
  venue           String?
  matchDate       DateTime
  format          String
  oversPerSide    Float
  ballsPerSide    Int?
  competitionType String
  status          String   @default("setup")
  scoredById      String?
  scoredBy        User?    @relation("ScoredBy", fields: [scoredById], references: [id])
  tossWinnerTeam  Int?
  tossElected     String?
  tossCaptain     String?
  coinResult      String?
  openingEnd      String?
  resultSummary   String?
  winnerTeamIndex Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  teams   MatchTeam[]
  innings Innings[]
}

model MatchTeam {
  id        String @id @default(uuid())
  matchId   String
  match     Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  teamIndex Int
  name      String
  color     String @default("#1D7948")

  players MatchPlayer[]
}

model MatchPlayer {
  id           String  @id @default(uuid())
  matchTeamId  String
  matchTeam    MatchTeam @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?   @relation(fields: [userId], references: [id])
  guestName    String?
  isGuest      Boolean @default(false)
  battingHand  String  @default("R")
  role         String  @default("Bat")
  isCaptain    Boolean @default(false)
  isWicketKeeper Boolean @default(false)
  inPlayingXI  Boolean @default(true)
  battingOrder Int?

  battingStats   BattingInningsStats[]
  bowlingStats   BowlingInningsStats[]
  keepingStats   KeepingInningsStats[]
  fieldingStats  FieldingInningsStats[]
  ballsFaced     Ball[] @relation("Batsman")
  ballsBowled    Ball[] @relation("Bowler")
  dismissals     Ball[] @relation("Dismissed")
}

model Innings {
  id            String @id @default(uuid())
  matchId       String
  match         Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  inningsNumber Int
  battingTeamIndex Int
  totalRuns     Int    @default(0)
  totalWickets  Int    @default(0)
  totalOvers    Float  @default(0)
  extrasWide    Int    @default(0)
  extrasNoBall  Int    @default(0)
  extrasLegBye  Int    @default(0)
  extrasBye     Int    @default(0)
  extrasPenalty Int    @default(0)
  isComplete    Boolean @default(false)

  balls Ball[]
}

model Ball {
  id              String  @id @default(uuid())
  inningsId       String
  innings         Innings @relation(fields: [inningsId], references: [id], onDelete: Cascade)
  overNumber      Int
  ballInOver      Int
  batsmanId       String
  batsman         MatchPlayer @relation("Batsman", fields: [batsmanId], references: [id])
  bowlerId        String
  bowler          MatchPlayer @relation("Bowler", fields: [bowlerId], references: [id])
  dismissedId     String?
  dismissed       MatchPlayer? @relation("Dismissed", fields: [dismissedId], references: [id])
  runsOffBat      Int     @default(0)
  extrasType      String?
  extrasRuns      Int     @default(0)
  isWicket        Boolean @default(false)
  wicketType      String?
  isLegalDelivery Boolean @default(true)
  shotType        String?
  shotDistance    Float?
  shotZone        String?
  shotAngle       Float?
  shotX           Float?
  shotY           Float?
}

model BattingInningsStats {
  id            String @id @default(uuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int
  runs          Int    @default(0)
  ballsFaced    Int    @default(0)
  fours         Int    @default(0)
  sixes         Int    @default(0)
  isOut         Boolean @default(false)
  dismissalType String?
  didBat        Boolean @default(true)
}

model BowlingInningsStats {
  id            String @id @default(uuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int
  overs         Float  @default(0)
  maidens       Int    @default(0)
  runs          Int    @default(0)
  wickets       Int    @default(0)
  wides         Int    @default(0)
  noBalls       Int    @default(0)
  didBowl       Boolean @default(false)
}

model KeepingInningsStats {
  id            String @id @default(uuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int
  catches       Int    @default(0)
  stumpings     Int    @default(0)
  byes          Int    @default(0)
  didKeep       Boolean @default(false)
}

model FieldingInningsStats {
  id            String @id @default(uuid())
  matchPlayerId String
  matchPlayer   MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)
  matchId       String
  inningsNumber Int
  catches       Int    @default(0)
  runOuts       Int    @default(0)
  didField      Boolean @default(true)
}
